{
  "name": "git-pr-ai",
  "version": "1.16.1",
  "description": "A tool to automatically extract JIRA ticket numbers from branch names and create GitHub/GitLab PRs",
  "type": "module",
  "bin": {
    "git-open-pr": "./dist/git-open-pr.mjs",
    "git-update-pr-desc": "./dist/git-update-pr-desc.mjs",
    "git-pr-review": "./dist/git-pr-review.mjs",
    "git-pr-ai": "./dist/git-pr-ai.mjs",
    "git-create-branch": "./dist/git-create-branch.mjs",
    "git-plan-issue": "./dist/git-plan-issue.mjs",
    "git-take-issue": "./dist/git-take-issue.mjs",
    "git-weekly-summary": "./dist/git-weekly-summary.mjs",
    "git-ai-commit": "./dist/git-ai-commit.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "dev": "vp pack --watch",
    "build": "vp pack",
    "postinstall": "test -f dist/postinstall.mjs && node dist/postinstall.mjs || echo 'Skipping git alias setup during build'",
    "test": "vp test",
    "test:ui": "vp test --ui",
    "test:run": "vp test run",
    "test:coverage": "vp test run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt --write .",
    "format:check": "vp fmt --check ."
  },
  "keywords": [
    "git",
    "github",
    "gitlab",
    "jira",
    "pull-request",
    "merge-request",
    "automation",
    "ai"
  ],
  "author": "leochiu-a",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/leochiu-a/git-pr-ai.git"
  },
  "homepage": "https://github.com/leochiu-a/git-pr-ai#readme",
  "bugs": {
    "url": "https://github.com/leochiu-a/git-pr-ai/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.8.0",
    "commander": "^14.0.0",
    "dayjs": "^1.11.13",
    "npm-check-updates": "^19.1.1",
    "ora": "^8.2.0",
    "zx": "^8.7.2"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@vitest/ui": "^2.1.8",
    "typescript": "^5.9.2",
    "vitest": "catalog:",
    "vite-plus": "catalog:"
  }
}
